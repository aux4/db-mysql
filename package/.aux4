{
  "scope": "aux4",
  "name": "db-mysql",
  "version": "2.0.1",
  "description": "mysql database tools",
  "tags": [
    "db",
    "database",
    "mysql"
  ],
  "dependencies": [
    "aux4/db"
  ],
  "profiles": [
    {
      "name": "db",
      "commands": [
        {
          "name": "mysql",
          "execute": [
            "profile:db:mysql"
          ],
          "help": {
            "text": "mysql database tools"
          }
        }
      ]
    },
    {
      "name": "db:mysql",
      "commands": [
        {
          "name": "execute",
          "execute": [
            "stdin:aux4 db driver prepare execute params(query, file, inputStream, tx, ignore) --params value(*) | node ${packageDir}/lib/aux4-db-mysql.js values(host, port, database, user, password)"
          ],
          "help": {
            "text": "Execute a query on the mysql database",
            "variables": [
              {
                "name": "host",
                "text": "Database host",
                "default": "localhost"
              },
              {
                "name": "port",
                "text": "Database port",
                "default": "3306"
              },
              {
                "name": "database",
                "text": "Database name",
                "default": "mysql"
              },
              {
                "name": "user",
                "text": "Database user",
                "default": "root"
              },
              {
                "name": "password",
                "text": "Database password"
              },
              {
                "name": "query",
                "text": "SQL query to execute",
                "default": "",
                "arg": true
              },
              {
                "name": "file",
                "text": "SQL file to execute",
                "default": ""
              },
              {
                "name": "inputStream",
                "text": "Read JSON input from stdin",
                "default": "false"
              },
              {
                "name": "tx",
                "text": "Use transaction for batch operations",
                "default": "false"
              },
              {
                "name": "ignore",
                "text": "Ignore errors and continue processing",
                "default": "false"
              }
            ]
          }
        },
        {
          "name": "stream",
          "execute": [
            "stdin:aux4 db driver prepare stream params(query, file, inputStream, tx, ignore) --params value(*) | node ${packageDir}/lib/aux4-db-mysql.js values(host, port, database, user, password)"
          ],
          "help": {
            "text": "Execute a query on the mysql database and stream results",
            "variables": [
              {
                "name": "host",
                "text": "Database host",
                "default": "localhost"
              },
              {
                "name": "port",
                "text": "Database port",
                "default": "3306"
              },
              {
                "name": "database",
                "text": "Database name",
                "default": "mysql"
              },
              {
                "name": "user",
                "text": "Database user",
                "default": "root"
              },
              {
                "name": "password",
                "text": "Database password"
              },
              {
                "name": "query",
                "text": "SQL query to execute",
                "default": ""
              },
              {
                "name": "file",
                "text": "SQL file to execute",
                "default": ""
              },
              {
                "name": "inputStream",
                "text": "Read JSON input from stdin",
                "default": "false"
              },
              {
                "name": "tx",
                "text": "Use transaction for batch operations",
                "default": "false"
              },
              {
                "name": "ignore",
                "text": "Ignore errors and continue processing",
                "default": "false"
              }
            ]
          }
        }
      ]
    }
  ]
}
